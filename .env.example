# WCL Baker — copy to .env and fill in values for local use.
# In CI, set WCL_CLIENT_ID and WCL_CLIENT_SECRET as GitHub repository Secrets,
# and the rest as GitHub repository Variables (Settings → Secrets and variables).

# Required — WCL API credentials (https://www.warcraftlogs.com/api/clients/)
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Required — default realm/region for all characters in players.data.ts
# All characters are assumed to be on the same realm unless the baker is extended.
# Realm slug is lowercase-hyphenated (e.g. gehennas, nethergarde-keep, firemaw).
WCL_DEFAULT_REALM=spineshatter
WCL_DEFAULT_REGION=eu

# Optional — filter rankings to a specific WCL zone ID.
# Leave blank to fetch all zones.
# TBC zone IDs: Karazhan=1010, Gruul's Lair=1011, Magtheridon's Lair=1012
# SSC=1004, TK=1005, Hyjal=1003, Black Temple=1002
WCL_ZONE_ID=

# Optional — set to "true" to skip gear fetching (faster, 1 API call per character instead of 4)
WCL_SKIP_GEAR=false

# Optional — milliseconds between API calls (default: 300)
WCL_API_DELAY_MS=50
